        "input": {
          "findings": [
            {
              "finding": "f",
              "id": "P2-a",
              "recommendation": "fix it",
              "requirement": "REQ-1",
              "severity": "P2",
              "source": "r1",
              "title": "a"
            },
            {
              "finding": "f",
              "id": "P3-b",
              "recommendation": "fix it",
              "requirement": "REQ-1",
              "severity": "P3",
              "source": "r1",
              "title": "b"
            }
          ],
          "threshold": 1
        },
        "name": "low_over_threshold"
