          "message": "converged"
        },
        "input": {
          "findings": [
            {
              "finding": "f",
              "id": "P2-a",
              "recommendation": "fix it",
              "requirement": "REQ-1",
              "severity": "P2",
              "source": "r1",
              "title": "a"
            }
          ],
          "threshold": 1
        },
        "name": "low_within_threshold"
      },
      {
        "expected": {
          "converged": false,
          "message": "2 low-severity finding(s) exceed threshold (1)"
